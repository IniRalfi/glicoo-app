# Glico Backend Environment Variables

# Supabase PostgreSQL Database Connection URL
# Pooler mode (pgbouncer=true) untuk serverless/Elysia
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection untuk Prisma migrations (tanpa pgbouncer)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"


# --- CONFIG AI (GEMINI & FALLBACK PROVIDER) ---
# API Key untuk Google Gemini (Utama)
GEMINI_API_KEY="ganti-dengan-api-key-gemini-anda"
GEMINI_MODEL="gemini-1.5-flash"

# Konfigurasi Fallback Provider (Groq / OpenAI / DeepSeek - Opsional)
OPENAI_API_KEY="ganti-dengan-api-key-openai-atau-groq"
OPENAI_BASE_URL="https://api.groq.com/openai/v1" # Contoh jika memakai Groq
OPENAI_MODEL="llama-3.1-70b-versatile"

# --- CONFIG TELEGRAM BOT ---
# Token Bot Telegram dari BotFather
TELEGRAM_BOT_TOKEN="ganti-dengan-token-bot-telegram-anda"
# Username Bot Telegram (Tanpa tanda @, misal: GlicoBot)
TELEGRAM_BOT_USERNAME="GlicoBot"
# --- CONFIG WHATSAPP BOT (OpenWA) ---
# Base URL OpenWA instance (deployed at wa.glicoo.my.id)
OPENWA_BASE_URL="https://wa.glicoo.my.id"
# API Key dari OpenWA Dashboard
OPENWA_API_KEY="ganti-dengan-api-key-openwa-anda"
# Session ID dari OpenWA Dashboard (bisa dicek via GET /api/sessions)
OPENWA_SESSION_ID="ganti-dengan-session-id-openwa-anda"
# Webhook Secret untuk verifikasi signature (gunakan string random panjang)
# Catatan: OpenWA Panel tidak support webhook signature, biarkan kosong
OPENWA_WEBHOOK_SECRET=""

# --- SECURITY CONFIG ---
# API Key khusus untuk rute admin dashboard / stats
BACKEND_ADMIN_API_KEY="dev-admin-key"

# --- ENVIRONMENT ---
# Set ke "production" saat deploy, "development" untuk local
NODE_ENV="development"

# --- CORS ---
# Origins yang diizinkan untuk akses API. Pisah dengan koma.
# Contoh production: https://glicoo.vercel.app,https://glicoo.my.id
ALLOWED_ORIGINS="http://localhost:3000"

# --- WEBHOOK & CRON ---
# Base URL backend untuk webhook Telegram/WhatsApp
WEBHOOK_URL="http://localhost:3000/"

# Cron Secret untuk protect cron endpoints (gunakan string random panjang min 32 char)
CRON_SECRET="ganti-dengan-cron-secret-random-32-chars-min"


# ============================================================
# .env.production.example — Backend Production Template
# ============================================================
# Salin file ini sebagai referensi saat set Environment Variables
# di Railway Dashboard (Settings → Variables).
# JANGAN isi secret nyata di file ini — ini hanya template.

# Database
# Pooler mode untuk serverless (pgbouncer=true)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection untuk migrations
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# --- CONFIG AI (GEMINI & FALLBACK PROVIDER) ---
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"

# Fallback Provider (Groq / OpenAI / DeepSeek)
OPENAI_API_KEY="YOUR_OPENAI_OR_COMPATIBLE_KEY"
OPENAI_BASE_URL="https://api.openmodel.ai/v1"
OPENAI_MODEL="deepseek-v4-flash"

# --- CONFIG TELEGRAM BOT ---
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_BOT_USERNAME="glicoo_bot"

# --- CONFIG WHATSAPP BOT (OpenWA) ---
OPENWA_BASE_URL="https://wa.glicoo.my.id"
OPENWA_API_KEY="YOUR_OPENWA_API_KEY"
OPENWA_SESSION_ID="YOUR_OPENWA_SESSION_ID"
# Catatan: OpenWA Panel tidak support webhook signature, biarkan kosong di Vercel env
OPENWA_WEBHOOK_SECRET=""

# --- SECURITY CONFIG ---
BACKEND_ADMIN_API_KEY="RANDOM_STRONG_ADMIN_KEY_32_CHARS_MIN"

# --- ENVIRONMENT ---
NODE_ENV="production"

# --- CORS ---
# Origins yang diizinkan, pisah dengan koma
ALLOWED_ORIGINS="https://glicoo.vercel.app,https://glicoo.my.id"

# --- WEBHOOK & CRON ---
# Base URL backend production (HTTPS)
WEBHOOK_URL="https://api.glicoo.my.id/"

# Cron Secret untuk protect cron endpoints
CRON_SECRET="RANDOM_STRONG_CRON_SECRET_KEY_32_CHARS_MIN"

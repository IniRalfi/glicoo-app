# ============================================================
# .env.production.example — Backend Production Template
# ============================================================
# Salin file ini sebagai referensi saat set Environment Variables
# di Railway Dashboard (Settings → Variables).
# JANGAN isi secret nyata di file ini — ini hanya template.

# Database (Railway akan inject DATABASE_URL otomatis jika pakai Railway Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# JWT — Ambil dari Supabase Dashboard → Settings → API → JWT Secret
JWT_SECRET="SUPABASE_JWT_SECRET_DARI_DASHBOARD"

# AI
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"
OPENAI_API_KEY="YOUR_OPENAI_OR_COMPATIBLE_KEY"
OPENAI_BASE_URL="https://api.openmodel.ai/v1"
OPENAI_MODEL="deepseek-v4-flash"

# Telegram
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_BOT_USERNAME="glicoo_bot"

# Security — Gunakan string random panjang (min 32 karakter)
BACKEND_ADMIN_API_KEY="RANDOM_STRONG_ADMIN_KEY_32_CHARS_MIN"

# Environment
NODE_ENV=production

# CORS — Domain frontend kamu yang sudah deploy
ALLOWED_ORIGINS=https://glicoo.vercel.app,https://yourdomain.com

# Webhook — URL Railway deployment kamu (otomatis HTTPS)
WEBHOOK_URL=https://glicoo-api.up.railway.app/

# Cron Trigger Token (Token pengaman untuk pemicu eksternal/cron-job.org)
CRON_SECRET="RANDOM_STRONG_CRON_SECRET_KEY_32_CHARS"
